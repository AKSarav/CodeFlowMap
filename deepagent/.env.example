# ─── CodeFlowMap Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Model ─────────────────────────────────────────────────────
# Uses LangChain's init_chat_model with provider:model format.
# See https://docs.langchain.com/oss/python/deepagents/customization#model
#
# Examples:
#   openai:gpt-4o                          OpenAI (default)
#   openai:gpt-4o-mini                     OpenAI (cheaper)
#   anthropic:claude-sonnet-4-6            Anthropic
#   anthropic:claude-3-haiku-20240307      Anthropic (cheaper)
#   google_genai:gemini-2.5-flash-lite     Google Gemini
#   google_genai:gemini-2.0-flash          Google Gemini
#   ollama:llama3                          Local via Ollama
#   azure_openai:gpt-4o                    Azure OpenAI
#   bedrock_converse:anthropic.claude-3-5-sonnet  AWS Bedrock
# CODEFLOWMAP_MODEL=openai:gpt-4o

# ─── Provider API Keys ─────────────────────────────────────────────
# Set the key for your chosen provider. LangChain reads these automatically.

# OpenAI
# OPENAI_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GOOGLE_API_KEY=...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# OPENAI_API_VERSION=2025-03-01-preview

# Ollama (local — no API key needed, just run: ollama serve)
# No env vars needed for local Ollama

# ─── Analysis Tuning (optional) ────────────────────────────────────
# CODEFLOWMAP_MAX_FILES=200
# CODEFLOWMAP_MAX_FILE_SIZE=80
# CODEFLOWMAP_MAX_CONTENT_CHARS=6000
# CODEFLOWMAP_MAX_TRACE_DEPTH=12
# CODEFLOWMAP_MAX_REACHABLE=300
